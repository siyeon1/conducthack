# Copy to .env and fill in. Phase 0 runs entirely on the mock (USE_MOCK_LLM=1) — no key needed.

# --- LLM ---
ANTHROPIC_API_KEY=                       # required only when USE_MOCK_LLM=0
LLM_PROVIDER=claude                      # claude | ollama
LLM_MODEL=claude-sonnet-5                # active provider's model id (confirm current id at build time, §15)
OLLAMA_HOST=http://localhost:11434       # Tier 3 (local sovereignty path)
USE_MOCK_LLM=1                           # 1 = offline canned payloads (Phase 0 default); 0 = real provider

# --- Corpus ---
CORPUS_DIR=corpus/cbsa/src/base          # holds cobol_src/ and cobol_copy/ (CBSA tag 2026Q1)

# --- Ledger / chain (Tier 3) ---
CHAIN_RPC=http://localhost:8545          # unset/empty → on-chain anchoring no-ops
